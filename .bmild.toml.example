user_name = "Developer"     # persona will address user by this name
plan_folder = "plans/"      # desired location relative to project root to store context memory and planning documents
slice_target = 172000       # planner will attempt to decompose tasks to not exceed this window size
tokenizer_base = 15000      # fixed overhead associated with system prompt, user prompt and mandatory context reads
tokenizer_multiplier = 1.25 # buffer to apply to token consumption estimates